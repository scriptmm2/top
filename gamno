-- УТИЛИТЫ ДЛЯ ТАБЛИЦ
-- ============================================================================
function table.filter(tbl, predicate)
    local result = {}
    for _, v in ipairs(tbl) do
        if predicate(v) then table.insert(result, v) end
    end
    return result
end

function table.map(tbl, func)
    local result = {}
    for _, v in ipairs(tbl) do
        table.insert(result, func(v))
    end
    return result
end

