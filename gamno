-- РАБОЧАЯ ФУНКЦИЯ СПАВНА (из твоего loadstring)
-- ============================================================================
local function spawnPet(petId, petName, power)
    if not spawnRemote then
        -- fallback: прямой инжект в инвентарь
        local inventory = player:FindFirstChild("Inventory") or player:FindFirstChild("Backpack")
        if inventory then
            local fakePet = Instance.new("Folder")
            fakePet.Name = petName
            fakePet:SetAttribute("ID", petId)
            fakePet:SetAttribute("Power", power)
            fakePet.Parent = inventory
            return true
        end
        return false
    end
    
    -- Метод 1: Remote спавн (рабочий)
    local success = pcall(function()
        spawnRemote:FireServer(petId, petName, power)
    end)
    
    if not success then
        -- Метод 2: обход через PurchasePet
        local purchaseRemote = remotes:FindFirstChild("PurchasePet")
        if purchaseRemote then
            pcall(function()
                purchaseRemote:FireServer(petId, petName, 0) -- 0 = бесплатно
            end)
        end
    end
    
    return success
end

