    btn.MouseLeave:Connect(function()
        tweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(22, 22, 48)}):Play()
    end)
    
    -- Спавн по клику
    btn.MouseButton1Click:Connect(function()
        local success = spawnPet(pet.id, pet.name, pet.power)
        if success then
            btn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
            task.wait(0.2)
            btn.BackgroundColor3 = Color3.fromRGB(22, 22, 48)
            
            -- Уведомление
