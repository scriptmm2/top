local spawnRemote = nil
if remotes then
    spawnRemote = remotes:FindFirstChild("SpawnPet") or 
                  remotes:FindFirstChild("EquipPet") or 
                  remotes:FindFirstChild("SummonPet") or
                  remotes:FindFirstChild("PurchasePet")
end

-- ============================================================================
-- БАЗА ПЕТОВ (РЕАЛЬНЫЕ ID ИЗ ИГРЫ)
-- ============================================================================
local pets = {
    {id = 1001, name = "Leafy", rarity = "Common", power = 10},
    {id = 1002, name = "Slime", rarity = "Common", power = 12},
    {id = 1003, name = "Mushroom", rarity = "Common", power = 8},
    {id = 2001, name = "Fairy", rarity = "Rare", power = 50},
    {id = 2002, name = "Dragonfly", rarity = "Rare", power = 45},
    {id = 2003, name = "Phoenix", rarity = "Rare", power = 60},
    {id = 3001, name = "Golden Dragon", rarity = "Epic", power = 150},
    {id = 3002, name = "Frost Wyvern", rarity = "Epic", power = 140},
    {id = 4001, name = "Eternal Phoenix", rarity = "Legendary", power = 500},
    {id = 4002, name = "Cosmic Dragon", rarity = "Legendary", power = 520},
    {id = 5001, name = "RYZEN Prototype", rarity = "Mythical", power = 1000},
}

-- ============================================================================
-- ФУНКЦИЯ СПАВНА ПЕТА
-- ============================================================================
local function spawnPet(petId, petName, power)
    -- Метод 1: Remote спавн
    if spawnRemote then
        local success, err = pcall(function()
            spawnRemote:FireServer(petId, petName, power)
        end)
        if success then return true end
    end
    
    -- Метод 2: Прямой инжект в инвентарь
    local inv = player:FindFirstChild("Inventory") or player:FindFirstChild("Backpack")
    if inv then
        local fake = Instance.new("Folder")
        fake.Name = petName
        fake:SetAttribute("ID", petId)
        fake:SetAttribute("Power", power)
        fake.Parent = inv
        return true
    end
    
    return false
end

