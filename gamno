scroll.ScrollBarThickness = 6
scroll.Parent = frame

-- Создание кнопок для каждого пета
for i, pet in ipairs(pets) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 48)
    btn.Position = UDim2.new(0, 5, 0, (i-1) * 52)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 60)
    btn.Text = pet.name .. " [" .. pet.rarity .. "] " .. pet.power .. "⚡"
    btn.TextColor3 = Color3.fromRGB(200, 200, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    btn.Parent = scroll
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    -- Цвет кнопки по редкости
    if pet.rarity == "Mythical" then
        btn.BackgroundColor3 = Color3.fromRGB(100, 0, 100)
        btn.TextColor3 = Color3.fromRGB(255, 0, 255)
    elseif pet.rarity == "Legendary" then
        btn.BackgroundColor3 = Color3.fromRGB(100, 80, 0)
        btn.TextColor3 = Color3.fromRGB(255, 215, 0)
    elseif pet.rarity == "Epic" then
        btn.BackgroundColor3 = Color3.fromRGB(70, 0, 120)
        btn.TextColor3 = Color3.fromRGB(170, 0, 255)
    elseif pet.rarity == "Rare" then
        btn.BackgroundColor3 = Color3.fromRGB(0, 60, 120)
        btn.TextColor3 = Color3.fromRGB(0, 150, 255)
    end
    
    btn.MouseButton1Click:Connect(function()
        local success = spawnPet(pet.id, pet.name, pet.power)
        
        -- Визуальный фидбек
        local originalColor = btn.BackgroundColor3
        if success then
            btn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
            task.wait(0.2)
            btn.BackgroundColor3 = originalColor
            
            -- Всплывающее уведомление
            local notif = Instance.new("TextLabel")
            notif.Size = UDim2.new(0, 250, 0, 35)
            notif.Position = UDim2.new(0.5, -125, 0.85, 0)
            notif.BackgroundColor3 = Color3.fromRGB(0, 50, 0)
            notif.Text = "✅ " .. pet.name .. " призван!"
            notif.TextColor3 = Color3.fromRGB(0, 255, 0)
            notif.TextScaled = true
            notif.Font = Enum.Font.Gotham
            notif.Parent = frame
            
            local notifCorner = Instance.new("UICorner")
            notifCorner.CornerRadius = UDim.new(0, 8)
            notifCorner.Parent = notif
            
            task.wait(2)
            notif:Destroy()
        else
            btn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
            task.wait(0.2)
            btn.BackgroundColor3 = originalColor
            
            local notif = Instance.new("TextLabel")
            notif.Size = UDim2.new(0, 250, 0, 35)
            notif.Position = UDim2.new(0.5, -125, 0.85, 0)
            notif.BackgroundColor3 = Color3.fromRGB(50, 0, 0)
            notif.Text = "❌ Ошибка спавна " .. pet.name
            notif.TextColor3 = Color3.fromRGB(255, 0, 0)
            notif.TextScaled = true
            notif.Font = Enum.Font.Gotham
            notif.Parent = frame
            
            local notifCorner = Instance.new("UICorner")
            notifCorner.CornerRadius = UDim.new(0, 8)
            notifCorner.Parent = notif
            
            task.wait(2)
            notif:Destroy()
        end
    end)
end

-- Анимация появления
frame.BackgroundTransparency = 1
